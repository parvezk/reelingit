# ReelingIt environment variables — copy to apps/api/.env and apps/web/.env
# See docs/supabase-setup.md for how to obtain these values.

# ----- apps/api (Express BFF) -----

# Supabase Postgres connection string. Use the POOLER URI (Transaction mode, port 6543)
# so short-lived / serverless API instances don't exhaust Postgres connections.
# Get this from Supabase Dashboard → Project Settings → Database → Connection string → URI (pooler).
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

PORT=4002
CORS_ORIGIN=http://localhost:3000

# ----- apps/web (Next.js) -----
NEXT_PUBLIC_API_URL=http://localhost:4002
